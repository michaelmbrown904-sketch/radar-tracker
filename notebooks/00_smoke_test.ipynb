   "source": [
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "\n",
    "t = np.linspace(0, 1, 1000)\n",
    "y = np.sin(2 * np.pi * 5 * t)\n",
    "\n",
    "plt.plot(t, y)\n",
    "plt.xlabel(\"Time (s)\")\n",
    "plt.ylabel(\"Amplitude\")\n",
    "plt.title(\"Hello, radar\")\n",
    "plt.show()"
   ]
